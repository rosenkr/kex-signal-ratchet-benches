diff --git a/rust/protocol/src/bench_metrics.rs b/rust/protocol/src/bench_metrics.rs
new file mode 100644
index 00000000..b9450a08
--- /dev/null
+++ b/rust/protocol/src/bench_metrics.rs
@@ -0,0 +1,38 @@
+use std::sync::atomic::{AtomicU64, Ordering};
+
+static DR_DH_RATCHET_COUNT: AtomicU64 = AtomicU64::new(0);
+static PQ_RATCHET_SEND_COUNT: AtomicU64 = AtomicU64::new(0);
+static PQ_RATCHET_RECV_COUNT: AtomicU64 = AtomicU64::new(0);
+
+pub fn reset_bench_dr_dh_ratchet_count() {
+    DR_DH_RATCHET_COUNT.store(0, Ordering::Relaxed);
+}
+
+pub fn reset_bench_pq_ratchet_count() {
+    PQ_RATCHET_SEND_COUNT.store(0, Ordering::Relaxed);
+    PQ_RATCHET_RECV_COUNT.store(0, Ordering::Relaxed);
+}
+
+pub fn bench_dr_dh_ratchet_count() -> u64 {
+    DR_DH_RATCHET_COUNT.load(Ordering::Relaxed)
+}
+
+pub fn bench_pq_ratchet_send_count() -> u64 {
+    PQ_RATCHET_SEND_COUNT.load(Ordering::Relaxed)
+}
+
+pub fn bench_pq_ratchet_recv_count() -> u64 {
+    PQ_RATCHET_RECV_COUNT.load(Ordering::Relaxed)
+}
+
+pub(crate) fn increment_bench_dr_dh_ratchet_count() {
+    DR_DH_RATCHET_COUNT.fetch_add(1, Ordering::Relaxed);
+}
+
+pub(crate) fn increment_bench_pq_ratchet_send_count() {
+    PQ_RATCHET_SEND_COUNT.fetch_add(1, Ordering::Relaxed);
+}
+
+pub(crate) fn increment_bench_pq_ratchet_recv_count() {
+    PQ_RATCHET_RECV_COUNT.fetch_add(1, Ordering::Relaxed);
+}
