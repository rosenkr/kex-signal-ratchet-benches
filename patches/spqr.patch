@@ -0,0 +1,59 @@
+use std::sync::atomic::{AtomicU64, Ordering};
+
+static BRAID_ADD_EPOCH_COUNT: AtomicU64 = AtomicU64::new(0);
+static SPQR_SEND_COUNT: AtomicU64 = AtomicU64::new(0);
+static SPQR_RECV_COUNT: AtomicU64 = AtomicU64::new(0);
+static CHAIN_SEND_KEY_COUNT: AtomicU64 = AtomicU64::new(0);
+static CHAIN_RECV_KEY_COUNT: AtomicU64 = AtomicU64::new(0);
+
+pub fn reset_bench_braid_ratchet_count() {
+    BRAID_ADD_EPOCH_COUNT.store(0, Ordering::Relaxed);
+}
+
+pub fn reset_bench_spqr_metrics() {
+    reset_bench_braid_ratchet_count();
+    SPQR_SEND_COUNT.store(0, Ordering::Relaxed);
+    SPQR_RECV_COUNT.store(0, Ordering::Relaxed);
+    CHAIN_SEND_KEY_COUNT.store(0, Ordering::Relaxed);
+    CHAIN_RECV_KEY_COUNT.store(0, Ordering::Relaxed);
+}
+
+pub fn bench_braid_ratchet_count() -> u64 {
+    BRAID_ADD_EPOCH_COUNT.load(Ordering::Relaxed)
+}
+
+pub fn bench_spqr_send_count() -> u64 {
+    SPQR_SEND_COUNT.load(Ordering::Relaxed)
+}
+
+pub fn bench_spqr_recv_count() -> u64 {
+    SPQR_RECV_COUNT.load(Ordering::Relaxed)
+}
+
+pub fn bench_chain_send_key_count() -> u64 {
+    CHAIN_SEND_KEY_COUNT.load(Ordering::Relaxed)
+}
+
+pub fn bench_chain_recv_key_count() -> u64 {
+    CHAIN_RECV_KEY_COUNT.load(Ordering::Relaxed)
+}
+
+pub(crate) fn increment_bench_braid_ratchet_count() {
+    BRAID_ADD_EPOCH_COUNT.fetch_add(1, Ordering::Relaxed);
+}
+
+pub(crate) fn increment_bench_spqr_send_count() {
+    SPQR_SEND_COUNT.fetch_add(1, Ordering::Relaxed);
+}
+
+pub(crate) fn increment_bench_spqr_recv_count() {
+    SPQR_RECV_COUNT.fetch_add(1, Ordering::Relaxed);
+}
+
+pub(crate) fn increment_bench_chain_send_key_count() {
+    CHAIN_SEND_KEY_COUNT.fetch_add(1, Ordering::Relaxed);
+}
+
+pub(crate) fn increment_bench_chain_recv_key_count() {
+    CHAIN_RECV_KEY_COUNT.fetch_add(1, Ordering::Relaxed);
+}
